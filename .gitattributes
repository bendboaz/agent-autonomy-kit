# Normalize all text to LF in the repo (these scripts/workflows run on Linux CI runners too).
* text=auto eol=lf

# Explicit: engine + CI files must be LF regardless of platform.
*.ps1  text eol=lf
*.py   text eol=lf
*.sh   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Binaries (none yet, but keep git from mangling them later).
*.png binary
*.jpg binary
*.gif binary
*.ico binary
